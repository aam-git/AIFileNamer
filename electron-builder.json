{
  "appId": "com.aifilenamer.app",
  "productName": "AIFileNamer",
  "publish": {
    "provider": "github",
    "owner": "aam-git",
    "repo": "AIFileNamer"
  },
  "copyright": "Copyright © 2026 AAMServices",
  "directories": {
    "output": "release",
    "buildResources": "public"
  },
  "files": [
    "dist/**/*",
    "main.cjs",
    "preload.cjs",
    "src/backend/**/*",
    "public/**/*",
    "package.json",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "public",
      "to": "public"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "public/favicon.ico"
  },
  "nsis": {
    "license": "public/license.txt",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "AIFileNamer",
    "installerIcon": "public/favicon.ico",
    "uninstallerIcon": "public/favicon.ico"
  },
  "mac": {
    "target": [
      {
        "target": "zip",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "icon": "public/favicon_green_512x512.png",
    "category": "public.app-category.productivity",
    "darkModeSupport": true
  },
  "dmg": {
    "title": "AIFileNamer",
    "icon": "public/favicon_green_512x512.png",
    "window": {
      "width": 540,
      "height": 380
    },
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "public/favicon_green_512x512.png",
    "category": "Utility",
    "synopsis": "AI-powered file organizer and renamer",
    "description": "AIFileNamer intelligently renames and organizes your files using AI — supports local and cloud models."
  }
}