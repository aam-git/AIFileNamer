{
  "name": "aifilenamer",
  "productName": "AIFileNamer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "author": {
    "name": "AIFileNamer",
    "email": "hello@aifilenamer.app"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "start": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dist": "vite build && electron-builder --config electron-builder.json",
    "dist:win": "vite build && electron-builder --win --config electron-builder.json",
    "dist:mac": "vite build && electron-builder --mac --config electron-builder.json",
    "dist:linux": "vite build && electron-builder --linux --config electron-builder.json",
    "dist:all": "vite build && electron-builder --win --mac --linux --config electron-builder.json",
    "dist:store-exe": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false CSC_LINK= CSC_KEY_PASSWORD= WIN_CSC_LINK= WIN_CSC_KEY_PASSWORD= electron-builder --win --config electron-builder.store-exe.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.0.12",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "ag-psd": "^30.1.1",
    "dexie": "^4.4.2",
    "exifr": "^7.1.3",
    "heic-decode": "^2.1.0",
    "jimp": "^1.6.1",
    "officeparser": "^7.0.3",
    "pdf-parse": "^2.4.5",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aam-git/AIFileNamer.git"
  }
}
